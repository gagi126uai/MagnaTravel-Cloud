POSTGRES_DB=travel
POSTGRES_USER=traveluser
POSTGRES_PASSWORD=change_this_postgres_password

JWT_KEY=CHANGE_THIS_SECRET_WITH_AT_LEAST_32_CHARS
SECURITY_ENCRYPTION_KEY=CHANGE_THIS_SECURITY_ENCRYPTION_KEY_WITH_AT_LEAST_32_CHARS
JWT_ISSUER=MagnaTravel
JWT_AUDIENCE=MagnaTravelUsers

# In VPS/production use the public ERP URL, for example https://erp.tu-dominio.com
WEB_ORIGIN=http://localhost:3000
WHATSAPP_WEBHOOK_SECRET=CHANGE_THIS_SECRET
METRICS_TOKEN=CHANGE_THIS_METRICS_TOKEN
RABBITMQ_USER=travelmq
RABBITMQ_PASSWORD=CHANGE_THIS_RABBITMQ_PASSWORD
MINIO_ROOT_USER=travelminio
MINIO_ROOT_PASSWORD=CHANGE_THIS_MINIO_ROOT_PASSWORD

# MassTransit + Outbox gating (C17 Fase A). Hoy lo activa solo el worker
# (hardcoded en docker-compose.yml). El api queda en false para que tests sin
# Rabbit no exploten. Si en el futuro el api necesita publicar mensajes,
# setear MassTransit__Enabled=true tambien en el bloque api del compose.
# MASSTRANSIT_ENABLED=true

# Leave empty to use same-origin requests through the web container's nginx proxy.
VITE_API_URL=

# Backups and database slow query logging
BACKUP_INTERVAL_SECONDS=86400
BACKUP_DAILY_RETENTION_DAYS=14
BACKUP_WEEKLY_RETENTION_DAYS=56
POSTGRES_SLOW_QUERY_MS=500

# Docker disk hygiene
DOCKER_LOG_MAX_SIZE=50m
DOCKER_LOG_MAX_FILE=3
DOCKER_CLEANUP_KEEP_HOURS=168
RUN_DOCKER_CLEANUP_AFTER_DEPLOY=false

# Space-separated CSP frame-ancestors values allowed to embed /embed/*.
# For VPS + Hostinger, include the public site domain that will host the iframe.
# Example: 'self' https://tu-sitio-hostinger.com https://www.tu-sitio-hostinger.com
EMBED_ALLOWED_FRAME_ANCESTORS='self'

# ============================================================
# Copiloto de IA (ADR-016 F0a). Apagado por default (flag EnableAiCopilot=false en el
# panel admin). Estas variables SOLO importan si un install va a prender el copiloto.
#
# IMPORTANTE: las 3 variables (BaseUrl, ApiKey, Model) deben ser del MISMO proveedor.
# Cambiar de proveedor = editar estas 3 + restart de api y worker. Cero cambios de codigo:
# la unica implementacion del cerebro es OpenAI-compatible y esta 100% parametrizada por env.
#
# Ai__ApiKey es un SECRETO: nunca se commitea, nunca se loguea, NUNCA va a la base de datos.
# Mismo manejo que JWT_KEY / MINIO_ROOT_PASSWORD. Dejar en CHANGE_THIS_* hasta cargar la real.
# ============================================================

# Endpoint OpenAI-compatible del proveedor (SIN el sufijo /chat/completions, lo agrega el codigo).
# Default = endpoint OpenAI-compatible del proveedor del piloto.
Ai__BaseUrl=https://api.groq.com/openai/v1

# API key del proveedor. SECRETO. Dejar el placeholder hasta cargar la real.
Ai__ApiKey=CHANGE_THIS_AI_API_KEY

# Nombre del modelo. OJO: VOLATIL. Los modelos del free tier cambian de nombre seguido —
# este valor es solo un ejemplo del free tier al momento de escribir esto y SE DEBE CONFIRMAR
# contra la lista de modelos vigentes del proveedor al configurar el install. Si el nombre
# quedo viejo, las llamadas degradan elegante (el copiloto no genera texto, no rompe nada).
Ai__Model=llama-3.3-70b-versatile

# Timeout por llamada al modelo, en segundos. Default 15.
Ai__TimeoutSeconds=15

# Tope de tokens de la respuesta por defecto. Acota costo y largo de salida. Default 512.
Ai__MaxTokens=512

# Maximo de reintentos (config). En F0a el cerebro usa solo 1 reintento ante JSON invalido;
# los reintentos completos de 429/5xx con backoff son de una fase posterior (F0b). Default 2.
Ai__MaxRetries=2
