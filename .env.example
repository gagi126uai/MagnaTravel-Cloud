POSTGRES_DB=travel
POSTGRES_USER=traveluser
POSTGRES_PASSWORD=change_this_postgres_password

JWT_KEY=CHANGE_THIS_SECRET_WITH_AT_LEAST_32_CHARS
SECURITY_ENCRYPTION_KEY=CHANGE_THIS_SECURITY_ENCRYPTION_KEY_WITH_AT_LEAST_32_CHARS
JWT_ISSUER=MagnaTravel
JWT_AUDIENCE=MagnaTravelUsers

# In VPS/production use the public ERP URL, for example https://erp.tu-dominio.com
WEB_ORIGIN=http://localhost:3000
WHATSAPP_WEBHOOK_SECRET=CHANGE_THIS_SECRET
METRICS_TOKEN=CHANGE_THIS_METRICS_TOKEN
RABBITMQ_USER=travelmq
RABBITMQ_PASSWORD=CHANGE_THIS_RABBITMQ_PASSWORD
MINIO_ROOT_USER=travelminio
MINIO_ROOT_PASSWORD=CHANGE_THIS_MINIO_ROOT_PASSWORD

# MassTransit + Outbox gating (C17 Fase A). Hoy lo activa solo el worker
# (hardcoded en docker-compose.yml). El api queda en false para que tests sin
# Rabbit no exploten. Si en el futuro el api necesita publicar mensajes,
# setear MassTransit__Enabled=true tambien en el bloque api del compose.
# MASSTRANSIT_ENABLED=true

# Leave empty to use same-origin requests through the web container's nginx proxy.
VITE_API_URL=

# Backups and database slow query logging
BACKUP_INTERVAL_SECONDS=86400
BACKUP_DAILY_RETENTION_DAYS=14
BACKUP_WEEKLY_RETENTION_DAYS=56
POSTGRES_SLOW_QUERY_MS=500

# Docker disk hygiene
DOCKER_LOG_MAX_SIZE=50m
DOCKER_LOG_MAX_FILE=3
DOCKER_CLEANUP_KEEP_HOURS=168
RUN_DOCKER_CLEANUP_AFTER_DEPLOY=false

# Space-separated CSP frame-ancestors values allowed to embed /embed/*.
# For VPS + Hostinger, include the public site domain that will host the iframe.
# Example: 'self' https://tu-sitio-hostinger.com https://www.tu-sitio-hostinger.com
EMBED_ALLOWED_FRAME_ANCESTORS='self'
