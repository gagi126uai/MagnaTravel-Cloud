# URL del webhook en tu ERP (ajustar si usas proxy reverso o dominio)
WEBHOOK_URL=http://localhost:5000/api/webhooks/whatsapp

# Secret compartido con el backend para autenticar las llamadas
WEBHOOK_SECRET=CHANGE_THIS_SECRET

# Timeout de sesión conversacional en minutos (default 30)
BOT_SESSION_TIMEOUT_MINUTES=30

# Mensaje de bienvenida personalizable (opcional)
# BOT_WELCOME_MESSAGE=¡Hola! Gracias por contactar a MagnaTravel 🌎
